<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required for Electron's V8 JIT compiler under Hardened Runtime -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- Required by Electron's renderer sandbox internals -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- Outbound HTTPS to fluxer.world -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- Needed for Web Notifications -->
  <key>com.apple.security.network.server</key>
  <true/>

  <!-- Allow loading dylibs not signed by Apple (bundled Node/Electron internals) -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
